{
  "css": [
    {
      "animId": "fade-up",
      "description": "Translate from +32 px, fade.",
      "usage": "Default for paragraph + card entry.",
      "cssCode": "@keyframes kf-fade-up{from{opacity:0;transform:translateY(32px)}to{opacity:1;transform:none}}.anim-fade-up{animation:kf-fade-up var(--anim-dur) var(--anim-ease) both}"
    },
    {
      "animId": "fade-down",
      "description": "Translate from -32 px, fade.",
      "usage": "Headers / banners / callouts.",
      "cssCode": "@keyframes kf-fade-down{from{opacity:0;transform:translateY(-32px)}to{opacity:1;transform:none}}.anim-fade-down{animation:kf-fade-down var(--anim-dur) var(--anim-ease) both}"
    },
    {
      "animId": "fade-left",
      "description": "Translate from -40 px.",
      "usage": "Left column in a two-column layout.",
      "cssCode": "@keyframes kf-fade-left{from{opacity:0;transform:translateX(-40px)}to{opacity:1;transform:none}}.anim-fade-left{animation:kf-fade-left var(--anim-dur) var(--anim-ease) both}"
    },
    {
      "animId": "fade-right",
      "description": "Translate from +40 px.",
      "usage": "Right column in a two-column layout.",
      "cssCode": "@keyframes kf-fade-right{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:none}}.anim-fade-right{animation:kf-fade-right var(--anim-dur) var(--anim-ease) both}"
    },
    {
      "animId": "rise-in",
      "description": "+60 px rise + blur-off.",
      "usage": "Slide titles, hero headlines.",
      "cssCode": "@keyframes kf-rise{from{opacity:0;transform:translateY(60px) scale(.97);filter:blur(6px)}to{opacity:1;transform:none;filter:none}}.anim-rise-in{animation:kf-rise .9s var(--anim-ease) both}"
    },
    {
      "animId": "drop-in",
      "description": "-60 px drop + slight scale.",
      "usage": "Banners, alert bars.",
      "cssCode": "@keyframes kf-drop{from{opacity:0;transform:translateY(-60px) scale(.97)}to{opacity:1;transform:none}}.anim-drop-in{animation:kf-drop .8s var(--anim-ease) both}"
    },
    {
      "animId": "zoom-pop",
      "description": "Scale 0.6 \u2192 1.04 \u2192 1.",
      "usage": "Buttons, stat numbers, CTAs.",
      "cssCode": "@keyframes kf-zoom{0%{opacity:0;transform:scale(.6)}60%{transform:scale(1.04)}100%{opacity:1;transform:scale(1)}}.anim-zoom-pop{animation:kf-zoom .7s cubic-bezier(.22,1.3,.36,1) both}"
    },
    {
      "animId": "blur-in",
      "description": "18 px blur clears.",
      "usage": "Cover page reveal.",
      "cssCode": "@keyframes kf-blur{from{opacity:0;filter:blur(18px)}to{opacity:1;filter:none}}.anim-blur-in{animation:kf-blur .8s var(--anim-ease) both}"
    },
    {
      "animId": "glitch-in",
      "description": "Clip-path steps + jitter.",
      "usage": "Tech / cyber / error states.",
      "cssCode": "@keyframes kf-glitch{0%{opacity:0;transform:translateX(0);clip-path:inset(0 0 0 0)}20%{opacity:1;transform:translateX(-6px);clip-path:inset(20% 0 30% 0)}40%{transform:translateX(4px);clip-path:inset(50% 0 10% 0)}60%{transform:translateX(-3px);clip-path:inset(10% 0 60% 0)}80%{transform:translateX(2px);clip-path:inset(0 0 0 0)}100%{opacity:1;transform:none}}.anim-glitch-in{animation:kf-glitch .8s steps(5,end) both}"
    },
    {
      "animId": "typewriter",
      "description": "Monospace-like type reveal.",
      "usage": "One-liners, slogans.",
      "cssCode": "@keyframes kf-type{to{width:100%}}@keyframes kf-caret{50%{border-color:transparent}}.anim-typewriter{display:inline-block;overflow:hidden;white-space:nowrap;border-right:2px solid currentColor;width:0;animation:kf-type 2.4s steps(40,end) forwards,kf-caret 1s step-end infinite}"
    },
    {
      "animId": "neon-glow",
      "description": "Cyclic text-shadow pulse.",
      "usage": "Terminal-green / dracula themes.",
      "cssCode": "@keyframes kf-neon{0%,100%{text-shadow:0 0 8px var(--accent),0 0 20px var(--accent)}50%{text-shadow:0 0 16px var(--accent),0 0 40px var(--accent),0 0 80px var(--accent)}}.anim-neon-glow{animation:kf-neon 2s ease-in-out infinite}"
    },
    {
      "animId": "shimmer-sweep",
      "description": "White sheen passes across.",
      "usage": "Metallic buttons, premium cards.",
      "cssCode": "@keyframes kf-shimmer{to{transform:translateX(100%)}}.anim-shimmer-sweep{position:relative;overflow:hidden}.anim-shimmer-sweep::after{content:\"\";position:absolute;inset:0;background:linear-gradient(110deg,transparent 40%,rgba(255,255,255,.55) 50%,transparent 60%);transform:translateX(-100%);animation:kf-shimmer 2.4s var(--anim-ease) infinite}"
    },
    {
      "animId": "gradient-flow",
      "description": "Infinite horizontal gradient slide.",
      "usage": "Brand wordmarks.",
      "cssCode": "@keyframes kf-gradflow{to{background-position:300% 0}}.anim-gradient-flow{background:linear-gradient(90deg,var(--accent),var(--accent-2,var(--accent)),var(--accent-3,var(--accent)),var(--accent));background-size:300% 100%;-webkit-background-clip:text;background-clip:text;color:transparent;-webkit-text-fill-color:transparent;animation:kf-gradflow 4s linear infinite}"
    },
    {
      "animId": "stagger-list",
      "description": "Children rise-in one-by-one.",
      "usage": "Any \u003cul\u003e or .grid.",
      "cssCode": ".anim-stagger-list > *{opacity:0;animation:kf-rise .65s var(--anim-ease) both}.anim-stagger-list > *:nth-child(1){animation-delay:.05s}.anim-stagger-list > *:nth-child(2){animation-delay:.15s}.anim-stagger-list > *:nth-child(3){animation-delay:.25s}.anim-stagger-list > *:nth-child(4){animation-delay:.35s}.anim-stagger-list > *:nth-child(5){animation-delay:.45s}.anim-stagger-list > *:nth-child(6){animation-delay:.55s}.anim-stagger-list > *:nth-child(7){animation-delay:.65s}.anim-stagger-list > *:nth-child(8){animation-delay:.75s}.anim-stagger-list > *:nth-child(n+9){animation-delay:.85s}"
    },
    {
      "animId": "counter-up",
      "description": "Number ticks 0 \u2192 target.",
      "usage": "KPI, stat-highlight pages.",
      "cssCode": ".counter{font-variant-numeric:tabular-nums}"
    },
    {
      "animId": "path-draw",
      "description": "Strokes draw themselves.",
      "usage": "Lines, arrows, diagrams.",
      "cssCode": "@keyframes kf-draw{to{stroke-dashoffset:0}}.anim-path-draw path,.anim-path-draw line,.anim-path-draw polyline,.anim-path-draw circle,.anim-path-draw rect{stroke-dasharray:1000;stroke-dashoffset:1000;animation:kf-draw 2s var(--anim-ease) forwards}"
    },
    {
      "animId": "morph-shape",
      "description": "Path d morph.",
      "usage": "Background shapes.",
      "cssCode": "@keyframes kf-morph{0%{d:path(\"M60,120 Q120,20 180,120 T300,120\")}100%{d:path(\"M60,120 Q120,220 180,120 T300,120\")}}.anim-morph-shape path{animation:kf-morph 6s ease-in-out infinite alternate}"
    },
    {
      "animId": "parallax-tilt",
      "description": "Hover \u2192 3D tilt.",
      "usage": "Hero cards, product shots.",
      "cssCode": ".anim-parallax-tilt{transform-style:preserve-3d;transition:transform .4s var(--anim-ease)}.anim-parallax-tilt:hover{transform:perspective(900px) rotateX(6deg) rotateY(-8deg) translateZ(10px)}"
    },
    {
      "animId": "card-flip-3d",
      "description": "Y-axis 90\u00b0 flip.",
      "usage": "Before/after reveal.",
      "cssCode": "@keyframes kf-flip{from{transform:perspective(1200px) rotateY(-90deg);opacity:0}to{transform:perspective(1200px) rotateY(0);opacity:1}}.anim-card-flip-3d{animation:kf-flip .9s var(--anim-ease) both;transform-style:preserve-3d;backface-visibility:hidden}"
    },
    {
      "animId": "cube-rotate-3d",
      "description": "Rotate in from a cube side.",
      "usage": "Section dividers.",
      "cssCode": "@keyframes kf-cube{from{transform:perspective(1200px) rotateX(20deg) rotateY(-90deg) translateZ(-200px);opacity:0}to{transform:perspective(1200px) rotateX(0) rotateY(0) translateZ(0);opacity:1}}.anim-cube-rotate-3d{animation:kf-cube 1s var(--anim-ease) both}"
    },
    {
      "animId": "page-turn-3d",
      "description": "Left-hinge page turn.",
      "usage": "Editorial / story flows.",
      "cssCode": "@keyframes kf-pageturn{from{transform:perspective(1600px) rotateY(-85deg);transform-origin:left center;opacity:0}to{transform:perspective(1600px) rotateY(0);opacity:1}}.anim-page-turn-3d{animation:kf-pageturn 1s var(--anim-ease) both;transform-origin:left center}"
    },
    {
      "animId": "perspective-zoom",
      "description": "Pull from -400 Z.",
      "usage": "Cover openings.",
      "cssCode": "@keyframes kf-pzoom{from{opacity:0;transform:perspective(1400px) translateZ(-400px) rotateX(12deg)}to{opacity:1;transform:none}}.anim-perspective-zoom{animation:kf-pzoom 1s var(--anim-ease) both}"
    },
    {
      "animId": "marquee-scroll",
      "description": "Infinite horizontal loop.",
      "usage": "Client logo strips.",
      "cssCode": "@keyframes kf-marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}.anim-marquee-scroll{display:flex;gap:48px;white-space:nowrap;animation:kf-marquee 20s linear infinite}"
    },
    {
      "animId": "kenburns",
      "description": "14 s slow zoom on images.",
      "usage": "Hero backgrounds.",
      "cssCode": "@keyframes kf-kenburns{0%{transform:scale(1) translate(0,0)}100%{transform:scale(1.15) translate(-2%,-1%)}}.anim-kenburns{animation:kf-kenburns 14s ease-in-out infinite alternate}"
    },
    {
      "animId": "confetti-burst",
      "description": "Pseudo-element sparkle burst.",
      "usage": "Thanks / win pages.",
      "cssCode": "@keyframes kf-confetti{0%{opacity:0;transform:scale(.2)}30%{opacity:1}100%{opacity:0;transform:scale(2.2)}}.anim-confetti-burst{position:relative}.anim-confetti-burst::before,.anim-confetti-burst::after{content:\"\";position:absolute;top:50%;left:50%;width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:20px -30px 0 var(--accent-2,var(--accent)),-25px -20px 0 var(--accent-3,var(--accent)),30px 20px 0 var(--good,#1aaf6c),-30px 25px 0 var(--warn,#f5a524),40px -10px 0 var(--bad,#e0445a),-45px 0 0 var(--accent),10px 40px 0 var(--accent-2,var(--accent)),-15px -40px 0 var(--accent-3,var(--accent));opacity:0;animation:kf-confetti 1.2s var(--anim-ease) forwards}.anim-confetti-burst::after{animation-delay:.15s;transform:rotate(45deg)}"
    },
    {
      "animId": "spotlight",
      "description": "Circular clip-path reveal.",
      "usage": "Big reveal moments.",
      "cssCode": "@keyframes kf-spot{0%{clip-path:circle(0% at 50% 50%)}100%{clip-path:circle(140% at 50% 50%)}}.anim-spotlight{animation:kf-spot 1.1s var(--anim-ease) both}"
    },
    {
      "animId": "ripple-reveal",
      "description": "Corner-origin ripple reveal.",
      "usage": "Section transitions.",
      "cssCode": "@keyframes kf-ripple{0%{clip-path:circle(0% at 20% 80%);opacity:.4}100%{clip-path:circle(160% at 20% 80%);opacity:1}}.anim-ripple-reveal{animation:kf-ripple 1.2s var(--anim-ease) both}"
    }
